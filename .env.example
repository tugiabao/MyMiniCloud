# =================================================================
# MYMINICLOUD - ENVIRONMENT CONFIGURATION EXAMPLE
# Copy file này thành .env và điền các thông tin bảo mật thực tế
# DÀNH CHO MÔI TRƯỜNG DOCKER COMPOSE NỘI BỘ MÁY CHỦ
# =================================================================

# --- THÔNG TIN CHUNG ---
NETWORK_NAME=cloud-net
DOMAIN_NAME=myminicloud.local
TIMEZONE=Asia/Ho_Chi_Minh
SUBNET_RANGE=172.19.0.0/16

# --- DATABASE (c3) ---
DB_IMAGE=postgres:15-alpine
DB_DRIVER=postgresql
DB_HOST=c3
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=your_db_password_here
DB_NAME=myminicloud_db
DB_SSL=false

# --- APP (c2 - NestJS Backend) ---
PORT_BACKEND=3000

# Keycloak OIDC
KEYCLOAK_URL=https://auth.azura.io.vn
KEYCLOAK_REALM=smart_aquarium

# --- AUTH (c4 - Keycloak) ---
AUTH_ADMIN=admin
AUTH_PASSWORD=your_auth_password_here

# --- STORAGE (c5 - MinIO) ---
STORAGE_USER=admin_minio
STORAGE_PASSWORD=your_storage_password_here
STORAGE_PORT_CONSOLE=9001
STORAGE_ACCESS_KEY=your_access_key_here
STORAGE_SECRET_KEY=your_secret_key_here

# --- MONITORING (c7 - Prometheus, c8 - Grafana) ---
GRAFANA_PORT_HOST=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_grafana_password_here

# --- STATIC IPs (c1-c10) ---
# Địa chỉ IP nội bộ cấp phát tĩnh đảm bảo Flow Request không bao giờ bị rối loạn
IP_C1=172.19.0.2
IP_C2=172.19.0.3
IP_C3=172.19.0.4
IP_C4=172.19.0.5
IP_C5=172.19.0.6
IP_C6=172.19.0.7
IP_C7=172.19.0.8
IP_C8=172.19.0.9
IP_C9=172.19.0.10
IP_C10=172.19.0.11
IP_CADVISOR=172.19.0.12
IP_C3_DBVIEW=172.19.0.13
IP_C1_BLOG=172.19.0.14

# --- CLOUDFLARE TUNNEL (c10) ---
# Lấy chuỗi Token từ Zero Trust Dashboard
TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# =================================================================
# --- SMART AQUARIUM ITP (c2 NestJS) ---
# Cấu hình tính năng mở rộng ứng dụng
# =================================================================

# HiveMQ (MQTT Broker Cloud)
MQTT_HOST=your_mqtt_host.hivemq.cloud
MQTT_PORT=8883
MQTT_USER=your_mqtt_username
MQTT_PASS=your_mqtt_password

# JWT & Auth redirect
APP_JWT_SECRET=your_super_secret_jwt_key_here
APP_JWT_EXPIRES=1d
AUTH_REDIRECT_URL=https://sa.azura.io.vn
GOOGLE_CALLBACK_URL=https://sa.azura.io.vn

# Mail SMTP Server Gửi cảnh báo
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password_here

# AI Service (chưa triển khai)
AI_SERVICE_SECRET=your_ai_secret_here
AI_SERVICE_URL=http://c11.myminicloud.local:5000
